# ── Required ──────────────────────────────────────────────────────────────────
# Shared secret sent as x-bioaccess-token header (same pattern as yutori-intake)
BIOACCESS_TOKEN=replace_with_strong_random_token

# ── Session ───────────────────────────────────────────────────────────────────
# Path to Playwright storage state JSON (cookies + localStorage)
# On Railway this lives on the persistent volume mounted at /data
SESSION_FILE=/data/session.json

# ── Webhook ───────────────────────────────────────────────────────────────────
SUPABASE_WEBHOOK_TOKEN=your_supabase_anon_or_service_key
SUPABASE_WEBHOOK_URL=https://zwtmyuzunfdnmhmlvapy.supabase.co/functions/v1/yutori-intake

# ── Optional ──────────────────────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info
PLAYWRIGHT_HEADLESS=true
